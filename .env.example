# ============================================================================
# AIOPS Agent 环境变量配置模板
# ============================================================================
#
# 使用方法：
#   1. cp .env.example .env
#   2. 编辑 .env，把下面「必须修改」的几项填上你的真实值
#   3. 「已内置默认值」的项不用改，除非你想调参数
#
# .env 文件不会被提交到 git（已在 .gitignore 中）
# ============================================================================

# ============================================================================
# 必须修改 —— 不填跑不起来
# ============================================================================

# DeepSeek API 密钥（去 platform.deepseek.com 申请）
DEEPSEEK_API_KEY=sk-your-api-key-here


# ============================================================================
# 使用诊断功能时必须修改 —— 不填 MCP 工具会返回"地址未配置"错误
# ============================================================================

# Prometheus 地址
PROMETHEUS_URL=http://192.168.101.100:9090

# Loki 地址
LOKI_URL=http://192.168.101.100:3100

# Jaeger 地址
JAEGER_URL=http://192.168.101.100:16686


# ============================================================================
# 以下可选 —— 去掉行首的 # 即可覆盖默认值
# ============================================================================

# 模型名（默认 deepseek-chat）
# LLM_MODEL=deepseek-chat

# API 地址（默认 https://api.deepseek.com/v1）
# 换成 OpenAI: https://api.openai.com/v1
# 换成 Ollama: http://localhost:11434/v1
# LLM_BASE_URL=https://api.deepseek.com/v1

# 温度参数（默认 0.0，确定性最强）
# LLM_TEMPERATURE=0.0

# HTTP 请求超时秒数（默认 30）
# TOOL_TIMEOUT=30

# Supervisor 最大调度轮数（默认 10）
# MAX_ITERATIONS=10

# 最大反思轮数（默认 2）
# MAX_REFLECTIONS=2

# 最低置信度阈值（默认 0.7）
# MIN_CONFIDENCE=0.7

# 单次诊断最大 token 量（默认 0 = 不限）
# MAX_TOKENS_PER_DIAGNOSIS=0

# Git 仓库路径（默认空 = 不启用代码变更分析）
# GIT_REPO_PATH=d:/py_project/AIOPS/microservices
