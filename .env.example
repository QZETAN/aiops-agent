# ============================================================================
# AIOPS Agent 环境变量配置模板
# ============================================================================
#
# 使用方法：
#   1. cp .env.example .env
#   2. 只改下面 DEEPSEEK_API_KEY 那一行，其他不用动
#
# 注意：
#   - 用 Docker Compose 一键部署时，Agent 容器内部自动走 Docker 网络，
#     不需要改下面的 URL（docker-compose.yml 已自动覆盖）
#   - 只在宿主机本地跑 Agent（不用 Docker）时才需要这些 URL
#   - 如果监控部署在远程服务器，把 localhost 换成服务器 IP
# ============================================================================

# ============================================================================
# 必填
# ============================================================================

DEEPSEEK_API_KEY=sk-your-api-key-here


# ============================================================================
# 监控后端地址
# ============================================================================
#
# localhost = 监控和 Agent 在同一台机器上
# 服务器IP = 监控在远程服务器，Agent 从别处访问
#
# 如果用 Docker Compose 一键部署，以下三行不用改，
# docker-compose.yml 会自动把容器内的正确地址注入给 Agent。

PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686


# ============================================================================
# 以下可选，不需要改
# ============================================================================

# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_TEMPERATURE=0.0
# TOOL_TIMEOUT=30
# MAX_ITERATIONS=10
# MAX_REFLECTIONS=2
# MIN_CONFIDENCE=0.7
# MAX_TOKENS_PER_DIAGNOSIS=0
# GIT_REPO_PATH=
